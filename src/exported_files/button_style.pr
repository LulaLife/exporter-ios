public struct {{ buttonStyleName(group.name) }}: ButtonStyle {
    @Environment(\.isEnabled) private var isEnabled

    public func makeBody(configuration: Configuration) -> some View {
        configuration.label
            .foregroundStyle(
                isEnabled
                    ? Color.Token.button{{ group.name }}Text
                    : Color.Token.button{{ group.name }}TextDisabled
            )
            .background(
                isEnabled
                    ? (configuration.isPressed
                        ? Color.Token.button{{ group.name }}BgPressed
                        : Color.Token.button{{ group.name }}Bg)
                    : Color.Token.button{{ group.name }}BgDisabled
            )
            {[ if hasBorder ]}
            .overlay(
                RoundedRectangle(cornerRadius: 8)
                    .stroke(
                        isEnabled
                            ? Color.Token.button{{ group.name }}Border
                            : Color.Token.button{{ group.name }}BorderDisabled,
                        lineWidth: 1
                    )
            )
            {[/]}
    }
}
